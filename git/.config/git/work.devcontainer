[user]
    name = zonghuazou
    email = zonghuazou@ddmarketinghub.com
    signingkey = ~/.ssh/id_ed25519_work.pub

[init]
    defaultBranch = main

[pull]
	rebase = true

[push]
    autoSetupRemote = true

[gpg]
	format = ssh

[fetch]
    prune = true

[commit]
	gpgsign = true

[url "git@github-work:"]
    insteadOf = https://github.com/
    insteadOf = git@github.com:
    insteadOf = git+ssh://git@github.com/
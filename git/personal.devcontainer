[user]
    name = zouzonghua
    email = zouzonghua.cn@gmail.com
    signingkey = ~/.ssh/id_ed25519_personal.pub

[init]
    defaultBranch = main

[pull]
	rebase = true

[push]
    autoSetupRemote = true

[fetch]
    prune = true

[gpg]
	format = ssh

[commit]
	gpgsign = true

[url "git@github-personal:"]
    insteadOf = https://github.com/
    insteadOf = git@github.com:
    insteadOf = git+ssh://git@github.com/